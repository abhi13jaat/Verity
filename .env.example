# LLM (OpenRouter — single key for chat, HyDE, vision)
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
FAST_LLM_MODEL=google/gemma-3-4b-it:free
# LLM_PROVIDER=                 # optional OpenRouter provider preference (e.g. Fireworks)

# Postgres  (port 5433 matches the docker-compose host mapping)
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5433/verity

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=verity_chunks

# Redis  (port 6380 matches the docker-compose host mapping)
REDIS_URL=redis://localhost:6380/0

# Web search fallback (optional)
# TAVILY_API_KEY=

# Tracing (optional — leave empty to disable)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# App
APP_ENV=development

# Auth — required. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-long-random-string
# ACCESS_TOKEN_EXPIRE_MINUTES=10080   # optional, default 7 days
